---
permalink: /workouts/index.html
layout: default
title: "Workouts"
description: "My Strava activities"
noPageHeader: true
---

<style>
  .workout-carousel {
    position: relative;
    width: 200px;
    height: 200px;
    flex-shrink: 0;
    border: 1px solid var(--ink);
  }

  .workout-carousel-inner {
    display: flex;
    overflow: hidden;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    width: 100%;
    height: 100%;
    scroll-behavior: smooth;
  }

  .workout-carousel-inner::-webkit-scrollbar {
    display: none;
  }

  .workout-carousel-item {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: start;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .workout-carousel-item svg {
    width: 100%;
    height: 100%;
    padding: 12px;
  }

  .workout-carousel-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .workout-carousel-dots {
    display: flex;
    justify-content: center;
    gap: 4px;
    padding: 4px 0;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
  }

  .workout-carousel-dot {
    width: 6px;
    height: 6px;
    background: var(--ink-3);
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .workout-carousel-dot.active {
    background: var(--accent);
  }

  .workout-item {
    display: flex;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--ink);
  }

  .workout-details {
    flex-grow: 1;
    min-width: 0;
  }

  .workout-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    margin: 0 0 4px;
    line-height: 1.2;
  }

  .workout-title a {
    color: var(--ink);
    text-decoration: none;
  }

  .workout-title a:hover {
    color: var(--accent);
  }

  .workout-time {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-2);
    display: block;
    margin-bottom: 14px;
  }

  .workout-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    border-top: 1px solid var(--ink);
    padding-top: 12px;
  }

  .workout-stat {
    display: flex;
    flex-direction: column;
  }

  .workout-stat-label {
    font-family: var(--font-display);
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-2);
    margin-bottom: 4px;
  }

  .workout-stat-value {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
  }

  .workout-item path {
    stroke: var(--accent);
    stroke-width: 10px;
    fill: none;
  }

  @media (max-width: 720px) {
    .workout-item {
      flex-direction: column;
    }
    .workout-carousel {
      width: 100%;
      height: 220px;
    }
    .workout-stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<header class="index-hero">
  <h1>WORKOUTS.</h1>
  <span class="meta">VIA STRAVA</span>
</header>

{%- for workout in workouts -%}
{% assign activity = workout.data.activity %}
{% if activity %}
{% assign has_svg = false %}
{% assign has_photos = false %}
{% assign photo_urls = "" | split: "" %}
{% if workout.svgPath %}{% assign has_svg = true %}{% endif %}

{%- comment -%}
Collect all photo URLs from either activity.photos.all (API response) or activity.photos.primary (webhook)
{%- endcomment -%}
{% if activity.photos.all %}
  {% for photo in activity.photos.all %}
    {% if photo.urls['600'] %}
      {% assign photo_urls = photo_urls | push: photo.urls['600'] %}
    {% endif %}
  {% endfor %}
  {% if photo_urls.size > 0 %}{% assign has_photos = true %}{% endif %}
{% elsif activity.photos.primary.urls %}
  {% assign photo_urls = photo_urls | push: activity.photos.primary.urls['600'] %}
  {% assign has_photos = true %}
{% endif %}

{% assign has_carousel = false %}
{% if has_svg or has_photos %}{% assign has_carousel = true %}{% endif %}
{% assign total_items = 0 %}
{% if has_svg %}{% assign total_items = total_items | plus: 1 %}{% endif %}
{% if has_photos %}{% assign total_items = total_items | plus: photo_urls.size %}{% endif %}

<div class="workout-item">
    {% if has_carousel %}
    <div class="workout-carousel">
        <div class="workout-carousel-inner">
            {% if has_svg %}
            <div class="workout-carousel-item">{% include workout.svgPath %}</div>
            {% endif %}
            {% if has_photos %}
              {% for photo_url in photo_urls %}
              <div class="workout-carousel-item">
                  <img src="{{ photo_url }}" alt="Photo {{ forloop.index }} from {{ activity.name }}" loading="lazy">
              </div>
              {% endfor %}
            {% endif %}
        </div>
        {% if total_items > 1 %}
        <div class="workout-carousel-dots">
            {% if has_svg %}
            <button class="workout-carousel-dot active" aria-label="View route map"></button>
            {% endif %}
            {% for photo_url in photo_urls %}
            <button class="workout-carousel-dot{% unless has_svg %}{% if forloop.first %} active{% endif %}{% endunless %}" aria-label="View photo {{ forloop.index }}"></button>
            {% endfor %}
        </div>
        {% endif %}
    </div>
    {% endif %}
    <div class="workout-details">
        <h2 class="workout-title"><a href="https://www.strava.com/activities/{{ activity.id }}" target="_blank" rel="noopener noreferrer">{{ activity.name }}</a></h2>
        <time class="workout-time">{{ activity.start_date | date: '%Y-%m-%d · %H:%M' }} UTC</time>

        <div class="workout-stats">
            {% if activity.distance %}
            <div class="workout-stat">
                <span class="workout-stat-label">Distance</span>
                <span class="workout-stat-value">{{ activity.distance | divided_by: 1000.0 | round: 2 }} km</span>
            </div>
            {% endif %}
            {% if activity.moving_time %}
            <div class="workout-stat">
                <span class="workout-stat-label">Duration</span>
                {% assign total_seconds = activity.moving_time %}
                {% assign minutes = total_seconds | divided_by: 60 | floor %}
                {% assign seconds = total_seconds | modulo: 60 | round %}
                {% assign padded_seconds = seconds | prepend: "0" | slice: -2, 2 %}
                <span class="workout-stat-value">{{ minutes }}:{{ padded_seconds }}</span>
            </div>
            {% endif %}
            {% if activity.average_speed %}
            <div class="workout-stat">
                <span class="workout-stat-label">Pace</span>
                <span class="workout-stat-value">
                    {% assign pace = 1000 | divided_by: activity.average_speed | divided_by: 60 %}
                    {% assign minutes = pace | floor %}
                    {% assign seconds = pace | minus: minutes | times: 60 | round %}
                    {{ minutes }}:{{ seconds | prepend: "0" | slice: -2, 2 }} /km
                </span>
            </div>
            {% endif %}
            {% if activity.average_heartrate %}
            <div class="workout-stat">
                <span class="workout-stat-label">Avg HR</span>
                <span class="workout-stat-value">{{ activity.average_heartrate | round }} bpm</span>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endif %} {%- endfor -%}

<script>
document.querySelectorAll('.workout-carousel').forEach(carousel => {
    const inner = carousel.querySelector('.workout-carousel-inner');
    const dots = carousel.querySelectorAll('.workout-carousel-dot');
    const items = carousel.querySelectorAll('.workout-carousel-item');

    if (dots.length === 0) return;

    dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
            if (items[index]) {
                items[index].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
            }
            dots.forEach((d, i) => d.setAttribute('aria-pressed', i === index));
        });
    });

    let scrollTimeout;
    inner.addEventListener('scroll', () => {
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(() => {
            const scrollLeft = inner.scrollLeft;
            const itemWidth = inner.offsetWidth;
            const activeIndex = Math.round(scrollLeft / itemWidth);

            dots.forEach((dot, index) => {
                dot.classList.toggle('active', index === activeIndex);
                dot.setAttribute('aria-pressed', index === activeIndex);
            });
        }, 50);
    });
});
</script>
